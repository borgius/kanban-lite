{
  "version": 2,
  "boards": {
    "default": {
      "name": "Default",
      "title": ["ticketId"],
      "metadata": ["ticketId", "location", "company", "position", "jobUrl", "salary"],
      "columns": [
        { "id": "backlog", "name": "Backlog", "color": "#6b7280" },
        { "id": "todo", "name": "To Do", "color": "#3b82f6" },
        { "id": "in-progress", "name": "In Progress", "color": "#f59e0b" },
        { "id": "review", "name": "Review", "color": "#8b5cf6" },
        { "id": "done", "name": "Done", "color": "#22c55e" }
      ],
      "nextCardId": 1,
      "defaultStatus": "backlog",
      "defaultPriority": "medium"
    }
  },
  "defaultBoard": "default",
  "kanbanDirectory": ".kanban",
  "defaultPriority": "medium",
  "defaultStatus": "backlog",
  "nextCardId": 1,
  "showPriorityBadges": false,
  "showAssignee": true,
  "showDueDate": true,
  "showLabels": true,
  "cardViewMode": "compact",
  "labels": {},
  "plugins": {
    "card.storage": { "provider": "cloudflare" },
    "config.storage": { "provider": "cloudflare" },
    "attachment.storage": { "provider": "cloudflare" },
    "webhook.delivery": { "provider": "webhooks" }
  }
}
