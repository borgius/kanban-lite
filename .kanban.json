  "forms": {
    "editorial-review": {
      "name": "Editorial Review",
      "description": "Capture a human review decision before publishing agent-generated content.",
      "schema": {
        "type": "object",
        "title": "Editorial Review",
        "properties": {
          "reviewStage": {
            "type": "string",
            "enum": [
              "draft-review",
              "fact-check",
              "publish-approval"
            ],
            "description": "Which stage is this review for?"
          },
          "decision": {
            "type": "string",
            "enum": [
              "needs-revision",
              "approved",
              "blocked"
            ]
          },
          "reviewer": {
            "type": "string",
            "minLength": 2,
            "description": "Who is making the decision?"
          },
          "voiceScore": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "default": 4,
            "description": "How well does the draft match the desired tone?"
          },
          "headlineApproved": {
            "type": "boolean",
            "description": "Is the headline ready to publish?"
          },
          "nextAction": {
            "type": "string",
            "enum": [
              "retry-draft",
              "request-fact-check",
              "approve-publish"
            ]
          },
          "notes": {
            "type": "string",
            "minLength": 10,
            "description": "Summarize the feedback or approval context."
          }
        },
        "required": [
          "reviewStage",
          "decision",
          "reviewer",
          "nextAction"
        ]
      },
      "ui": {
        "type": "VerticalLayout",
        "elements": [
          {
            "type": "HorizontalLayout",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/reviewStage"
              },
              {
                "type": "Control",
                "scope": "#/properties/decision"
              },
              {
                "type": "Control",
                "scope": "#/properties/reviewer"
              }
            ]
          },
          {
            "type": "HorizontalLayout",
            "elements": [
              {
                "type": "Control",
                "scope": "#/properties/voiceScore"
              },
              {
                "type": "Control",
                "scope": "#/properties/headlineApproved"
              },
              {
                "type": "Control",
                "scope": "#/properties/nextAction"
              }
            ]
          },
          {
            "type": "Control",
            "scope": "#/properties/notes",
            "options": {
              "multi": true
            }
          }
        ]
      },
      "data": {
        "reviewStage": "publish-approval",
        "decision": "approved",
        "reviewer": "Maya",
        "voiceScore": 4,
        "headlineApproved": true,
        "nextAction": "approve-publish",
        "notes": "Tone is clear and human. Approved once the final screenshot is added to the article."
      }
    }
  },
