# ── AI provider ────────────────────────────────────────────────────────────────
# Required unless you swap for a different @ai-sdk/* provider (see README).
# Sign up at https://platform.openai.com and create a key.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ── kanban-lite connection ──────────────────────────────────────────────────────
# URL to a running kanban-lite standalone server.
# Start one with: npx kanban-lite serve   (or: pnpm dlx kanban-lite serve)
KANBAN_API_URL=http://localhost:3000

# Board ID to use for chat triage tasks. "default" targets the default board.
KANBAN_BOARD_ID=default

# Optional: Bearer token string when the server has the kl-auth-plugin enabled.
# Leave blank for open-access (default) servers.
KANBAN_API_TOKEN=

# Set to "true" to use an in-memory mock instead of a live kanban-lite server.
# All board operations are simulated in-process — no server needed.
KANBAN_USE_MOCK=false
