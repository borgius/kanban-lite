{
  "name": "chat-sdk-vercel-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Kanban-lite chat triage demo — Vercel AI SDK + Next.js",
  "scripts": {
    "dev": "node ./scripts/run-local-stack.mjs dev",
    "dev:chat": "next dev --port 3001",
    "dev:kanban": "tsx ../../packages/kanban-lite/src/standalone/index.ts --config ./demo-workspace/.kanban.json --dir ./demo-workspace/.kanban --port 3000 --no-browser",
    "build": "next build",
    "start": "node ./scripts/run-local-stack.mjs start",
    "start:chat": "next start --port 3001",
    "start:kanban": "tsx ../../packages/kanban-lite/src/standalone/index.ts --config ./demo-workspace/.kanban.json --dir ./demo-workspace/.kanban --port 3000 --no-browser",
    "test": "npm run test:integration",
    "test:integration": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.0",
    "ai": "^4.3.0",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
