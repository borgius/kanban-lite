# kanban-lite server base URL
# Start the server first: kl serve   (or: kanban-md)
# Then open http://localhost:3000 to confirm it is running.
KANBAN_LITE_URL=http://localhost:3000

# LangGraph thread ID
# Each unique value is an independent durable execution session.
# Change this to start a fresh orchestration run from scratch.
THREAD_ID=backlog-review-001

# ── LLM provider keys (only needed if you replace the rule-based proposal ───
# engine with an LLM — see README § "Swapping in an LLM")
# OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
