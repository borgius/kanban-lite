# ── AI Model Provider ──────────────────────────────────────────────────────────
# The Coordinator agent uses OpenAI by default via @ai-sdk/openai.
# Swap to any supported AI SDK provider by editing src/mastra/agents/coordinator.ts.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ── kanban-lite Server ─────────────────────────────────────────────────────────
# Start the kanban-lite standalone server in a separate terminal before running
# this example app:
#
#   npx kanban-lite serve --port 3001
#
# Use a port different from the Next.js dev port (3002 by default).
KANBAN_API_URL=http://localhost:3001/api
