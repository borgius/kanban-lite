{
  "name": "@kanban-lite/workspace",
  "private": true,
  "description": "Private workspace controller for the kanban-lite monorepo.",
  "version": "1.3.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/borgius/kanban-lite"
  },
  "bugs": {
    "url": "https://github.com/borgius/kanban-lite/issues"
  },
  "homepage": "https://github.com/borgius/kanban-lite#readme",
  "scripts": {
    "minio:up": "docker compose up -d minio minio-init",
    "minio:down": "docker compose down",
    "build": "pnpm --filter './packages/*' --if-present run build",
    "build:workspace": "pnpm --filter './packages/*' --if-present run build",
    "cli": "pnpm --filter kanban-lite cli",
    "mcp": "pnpm --filter kanban-lite mcp",
    "start": "pnpm run build && pnpm --filter kanban-lite build:standalone-server && node packages/kanban-lite/dist/standalone.js",
    "standalone": "pnpm --filter kanban-lite standalone",
    "watch": "pnpm --filter kanban-lite watch",
    "watch:workspace": "pnpm --filter './packages/*' --if-present run watch",
    "dev": "pnpm --filter kanban-lite dev",
    "dev:ext": "pnpm --filter kanban-lite dev:ext",
    "dev:workspace": "pnpm --filter './packages/*' --if-present run dev",
    "test": "pnpm --filter kanban-lite test",
    "test:workspace": "pnpm --filter './packages/*' --if-present run test",
    "test:integration": "pnpm --filter kanban-lite --if-present run test:integration:minio",
    "test:integration:minio": "pnpm --filter kanban-lite --if-present run test:integration:minio",
    "test:plugins:integration": "pnpm --filter 'kl-*' --if-present run test:integration",
    "test:plugins:mysql": "pnpm --filter kl-plugin-storage-mysql run test:integration",
    "test:plugins:mysql:service": "pnpm --filter kl-plugin-storage-mysql run test:integration:service",
    "test:plugins:postgresql": "pnpm --filter kl-plugin-storage-postgresql run test:integration",
    "test:plugins:postgresql:service": "pnpm --filter kl-plugin-storage-postgresql run test:integration:service",
    "test:watch": "pnpm --filter kanban-lite test:watch",
    "test:watch:workspace": "pnpm --filter './packages/*' --if-present run test:watch",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:root": "playwright test --config=playwright.config.ts",
    "test:e2e:prepare": "tsx packages/kanban-lite/e2e/prepare-fixture.ts",
    "standalone:e2e": "pnpm run test:e2e:prepare && pnpm --filter kanban-lite run standalone:e2e:serve",
    "lint": "pnpm --filter kanban-lite lint",
    "lint:workspace": "pnpm --filter './packages/*' --if-present run lint",
    "typecheck": "pnpm --filter kanban-lite typecheck",
    "typecheck:workspace": "pnpm --filter './packages/*' --if-present run typecheck",
    "docs": "pnpm --filter kanban-lite docs",
    "docs:workspace": "pnpm --filter './packages/*' --if-present run docs",
    "docs:root": "pnpm run docs:root:sdk && pnpm run docs:root:api && pnpm run docs:root:webhooks",
    "docs:root:sdk": "npx tsx scripts/generate-sdk-docs.ts",
    "docs:root:api": "npx tsx scripts/generate-api-docs.ts",
    "docs:root:webhooks": "npx tsx scripts/generate-webhooks-docs.ts",
    "screenshots": "npx tsx scripts/take-screenshots.ts",
    "site:build": "pnpm --filter @kanban-lite/docs-site build",
    "site:dev": "pnpm --filter @kanban-lite/docs-site dev",
    "site:deploy": "pnpm --filter @kanban-lite/docs-site run deploy",
    "package": "vsce package --no-dependencies -o releases/",
    "release": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "release:github": "node scripts/release.mjs github",
    "release:check-auth": "node scripts/release.mjs check-auth",
    "link": "pnpm --filter './packages/*' exec pnpm link --global"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "esbuild": "^0.19.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdoc-to-markdown": "^9.1.3",
    "ovsx": "^0.10.8",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.53.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
