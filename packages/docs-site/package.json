{
  "name": "@kanban-lite/docs-site",
  "version": "0.0.1",
  "private": true,
  "description": "Eleventy-powered product and documentation website for kanban-lite.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "npm run clean",
    "build": "eleventy",
    "dev": "eleventy --serve --incremental",
    "clean": "node -e \"require('fs').rmSync('_site', { recursive: true, force: true })\"",
    "deploy": "eleventy && gh-pages -d _site"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.0",
    "gh-pages": "^6.3.0"
  }
}
