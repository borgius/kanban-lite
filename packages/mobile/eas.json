{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "env": {
        "EXPO_USE_LOCAL_CLI": "1"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "preview"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "env": {
        "APP_VARIANT": "production"
      }
    }
  }
}
